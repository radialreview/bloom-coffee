# Database (production only — development/test use config/database.yml defaults)
# DATABASE_URL=postgres://user:password@host:5432/bloom_coffee_production

# Rails master key (production only — decrypts credentials.yml.enc)
# RAILS_MASTER_KEY=your_master_key_here

# Admin seed credentials (optional — defaults shown)
SEED_ADMIN_EMAIL=admin@bloomcoffee.com
SEED_ADMIN_PASSWORD=INeedCaffeine!123

# Mailer host for generated URLs (production only)
# MAILER_HOST=your-app.onrender.com
