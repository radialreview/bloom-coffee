<%
  current = request.path
  tab_base   = "flex-1 flex flex-col items-center justify-center gap-0.5 min-h-11 px-2 py-2 text-[0.6875rem] font-semibold no-underline transition active:opacity-70"
  active_cls = "text-amber-800"
  inactive_cls = "text-stone-400"
%>

<nav
  class="fixed inset-x-0 bottom-0 z-20 flex min-h-14 bg-cream/90 backdrop-blur-md border-t border-cream-dark"
  style="padding-bottom: env(safe-area-inset-bottom);"
  role="navigation"
  aria-label="Primary">

  <%= link_to root_path, class: "#{tab_base} #{current == root_path ? active_cls : inactive_cls}" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;flex-shrink:0;">
      <path d="M18 8h1a4 4 0 010 8h-1"/><path d="M2 8h16v9a4 4 0 01-4 4H6a4 4 0 01-4-4V8z"/><line x1="6" y1="1" x2="6" y2="4"/><line x1="10" y1="1" x2="10" y2="4"/><line x1="14" y1="1" x2="14" y2="4"/>
    </svg>
    <span>Menu</span>
  <% end %>

  <%= link_to cart_path, class: "relative #{tab_base} #{current == cart_path ? active_cls : inactive_cls}" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;flex-shrink:0;">
      <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/>
    </svg>
    <span>Cart</span>
    <% cart_count = cart_item_count %>
    <% if cart_count > 0 %>
      <span class="absolute top-1 right-[calc(50%-1rem)] flex h-4 min-w-4 items-center justify-center rounded-full bg-amber-800 px-1 text-[0.625rem] font-bold text-white">
        <%= cart_count %>
      </span>
    <% end %>
  <% end %>

  <%= link_to orders_path, class: "#{tab_base} #{current == orders_path || current.start_with?('/orders') ? active_cls : inactive_cls}" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;flex-shrink:0;">
      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
    </svg>
    <span>Order</span>
  <% end %>

  <%= link_to settings_path, class: "#{tab_base} #{current == settings_path || current.start_with?('/admin') ? active_cls : inactive_cls}" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width:20px;height:20px;flex-shrink:0;">
      <circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83 0 2 2 0 010-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 010-2.83 2 2 0 012.83 0l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 0 2 2 0 010 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z"/>
    </svg>
    <span>Settings</span>
  <% end %>
</nav>
