<% content_for :title, "Bloom Coffee" %>

<section class="w-full max-w-[800px] mx-auto mt-[clamp(0.5rem,4vh,2rem)] px-4">
  <div class="text-center mb-6">
    <h1 class="m-0 text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-serif font-bold tracking-tight text-amber-900">
      Bloom Coffee
    </h1>
    <p class="mt-2 mb-0 text-base md:text-lg lg:text-xl text-stone-500">
      What can we brew for you today?
    </p>
  </div>

  <% if @drinks.any? %>
    <div class="flex items-center gap-3 mb-3">
      <span class="text-xs font-semibold uppercase tracking-widest text-amber-800">Menu</span>
      <div class="flex-1 h-px bg-stone-200"></div>
    </div>
    <ul class="list-none p-0 m-0 grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-4">
      <% @drinks.each do |drink| %>
        <li class="bg-white border border-stone-200 rounded-xl shadow-sm transition hover:shadow-md hover:bg-amber-50/50 hover:-translate-y-0.5">
          <%= link_to menu_path(drink), class: "flex flex-col justify-between h-full p-4 md:p-5 lg:p-6 no-underline" do %>
            <div>
              <h2 class="m-0 text-base md:text-lg lg:text-xl font-semibold text-stone-900"><%= drink.name %></h2>
              <% if drink.description.present? %>
                <p class="mt-1 mb-0 text-xs md:text-sm text-stone-500 line-clamp-2"><%= drink.description %></p>
              <% end %>
            </div>
            <span class="mt-3 text-sm md:text-base lg:text-lg font-semibold text-amber-900"><%= number_to_currency(drink.price) %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="text-center text-stone-500">No drinks on the menu yet. Check back soon.</p>
  <% end %>
</section>
