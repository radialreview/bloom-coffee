<% content_for :title, @drink.name %>

<section class="w-full max-w-md mx-auto mt-[clamp(1rem,6vh,3rem)] px-4">
  <div class="bg-white border border-stone-200 rounded-xl p-5 shadow-sm">
    <p class="m-0 text-xs font-semibold uppercase tracking-wide text-amber-800">Customize</p>
    <h1 class="mt-1 mb-0 text-xl font-serif font-bold text-stone-900"><%= @drink.name %></h1>
    <% if @drink.description.present? %>
      <p class="mt-1 mb-0 text-sm text-stone-500"><%= @drink.description %></p>
    <% end %>
    <p class="mt-2 mb-0 text-base font-semibold text-stone-800">
      Base price: <%= number_to_currency(@drink.price) %>
    </p>

    <%= form_with url: cart_items_path, method: :post, class: "mt-4", data: { controller: "line-total", line_total_base_price_value: @drink.price } do |f| %>
      <input type="hidden" name="order_item[drink_id]" value="<%= @drink.id %>">

      <% if @add_ons.any? %>
        <fieldset class="mt-2 border-0 p-0 m-0">
          <legend class="text-sm font-semibold text-stone-700">Add extras</legend>
          <div class="mt-2 flex flex-col gap-2 max-h-60 overflow-y-auto">
            <% @add_ons.each do |add_on| %>
              <label class="flex cursor-pointer items-center gap-3 rounded-lg border border-stone-200 px-3 py-2.5 transition hover:border-stone-300 hover:bg-stone-50 has-[:checked]:border-amber-800/40 has-[:checked]:bg-amber-50/20">
                <input type="checkbox"
                       name="order_item[order_item_add_ons_attributes][][add_on_id]"
                       value="<%= add_on.id %>"
                       data-line-total-target="checkbox"
                       data-price="<%= add_on.price %>"
                       data-action="change->line-total#calculate"
                       class="h-4 w-4 rounded border-stone-300 text-amber-800 focus:ring-amber-500">
                <span class="flex flex-1 items-center justify-between">
                  <span class="text-sm font-medium text-stone-800"><%= add_on.name %></span>
                  <span class="text-sm font-semibold text-stone-500">+<%= number_to_currency(add_on.price) %></span>
                </span>
              </label>
            <% end %>
          </div>
        </fieldset>
      <% end %>

      <div class="mt-4 flex items-center justify-between rounded-lg bg-amber-50/50 px-3 py-2.5">
        <span class="text-sm font-medium text-stone-600">Item total</span>
        <span class="text-lg font-bold text-amber-900" data-line-total-target="display">
          <%= number_to_currency(@drink.price) %>
        </span>
      </div>

      <div class="mt-4 flex items-center gap-3">
        <input type="hidden" name="order_item[quantity]" value="1">
        <%= f.submit "Add to order", class: "flex-1 cursor-pointer rounded-lg bg-amber-800 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" %>
        <%= link_to "Back", root_path, class: "rounded-lg border border-stone-300 bg-white px-4 py-2 text-sm font-semibold text-stone-700 transition hover:bg-stone-50" %>
      </div>
    <% end %>
  </div>
</section>
