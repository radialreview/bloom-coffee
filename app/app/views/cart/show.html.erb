<section class="w-full max-w-md mx-auto mt-[clamp(1rem,6vh,3rem)] px-4">
  <h1 class="m-0 mb-3 text-2xl font-serif font-bold tracking-tight text-center">Your Cart</h1>

  <div class="bg-white border border-stone-200 rounded-xl p-5 shadow-sm">
    <% if @order_items.any? %>
      <div class="mb-4">
        <%= link_to "\u2190 Back to menu", root_path,
              class: "text-sm font-semibold text-amber-800 no-underline hover:text-amber-700" %>
      </div>

      <div class="flex flex-col gap-2">
        <% @order_items.each do |item| %>
          <%= render "cart/items/order_item", order_item: item %>
        <% end %>
      </div>

      <div class="mt-4 flex items-center justify-between border-t border-stone-200 pt-4">
        <span class="text-base font-medium text-stone-700">Order total</span>
        <span class="text-lg font-bold text-amber-900"><%= number_to_currency(@order.total) %></span>
      </div>

      <div class="mt-4 text-center">
        <%= link_to "+ Add more drinks", root_path,
              class: "inline-flex items-center justify-center rounded-lg border border-stone-300 bg-white px-4 py-2.5 text-sm font-semibold text-stone-700 transition hover:bg-stone-50" %>
      </div>

      <div class="mt-4 rounded-lg border border-stone-200 bg-stone-50/50 p-4">
        <h2 class="m-0 text-base font-bold text-stone-900">Ready to order?</h2>
        <%= form_with url: orders_path, method: :post, class: "mt-3" do |f| %>
          <div>
            <label for="order_customer_name" class="block text-sm font-medium text-stone-700">Name for pickup</label>
            <input type="text" name="order[customer_name]" id="order_customer_name"
                   value="<%= @order.customer_name %>"
                   placeholder="e.g. Sam"
                   class="mt-1 block w-full rounded-lg border border-stone-300 bg-white px-3 py-2.5 text-stone-900 shadow-sm transition placeholder:text-stone-400 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/30">
          </div>
          <div class="mt-3">
            <%= f.submit "Place order", class: "cursor-pointer rounded-lg bg-amber-800 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-amber-700 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="py-4 text-center">
        <p class="m-0 text-stone-500">Your cart is empty.</p>
        <div class="mt-4">
          <%= link_to "Browse the menu", root_path,
                class: "inline-flex rounded-lg bg-amber-800 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-amber-700" %>
        </div>
      </div>
    <% end %>
  </div>
</section>
