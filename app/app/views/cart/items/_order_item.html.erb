<div class="flex flex-col gap-2 rounded-lg border border-stone-200 bg-stone-50/50 p-3 sm:flex-row sm:items-center sm:justify-between">
  <div class="flex-1">
    <h3 class="m-0 text-sm font-semibold text-stone-900"><%= order_item.drink.name %></h3>
    <% if order_item.add_ons.any? %>
      <p class="mt-0.5 mb-0 text-xs text-stone-500">
        + <%= order_item.add_ons.map(&:name).join(", ") %>
      </p>
    <% end %>
    <p class="mt-0.5 mb-0 text-xs text-stone-600">
      <%= number_to_currency(order_item.unit_price) %> each
    </p>
  </div>

  <div class="flex items-center gap-2">
    <div class="flex items-center gap-1">
      <% if order_item.quantity > 1 %>
        <%= button_to cart_item_path(order_item), method: :patch, params: { quantity: order_item.quantity - 1 }, class: "flex h-7 w-7 items-center justify-center rounded-md border border-stone-300 bg-white text-stone-700 transition hover:bg-stone-100" do %>
          <span class="text-xs font-bold">−</span>
        <% end %>
      <% else %>
        <span class="flex h-7 w-7 items-center justify-center rounded-md border border-stone-200 bg-stone-100 text-stone-400">
          <span class="text-xs font-bold">−</span>
        </span>
      <% end %>

      <span class="w-7 text-center text-sm font-semibold text-stone-900"><%= order_item.quantity %></span>

      <%= button_to cart_item_path(order_item), method: :patch, params: { quantity: order_item.quantity + 1 }, class: "flex h-7 w-7 items-center justify-center rounded-md border border-stone-300 bg-white text-stone-700 transition hover:bg-stone-100" do %>
        <span class="text-xs font-bold">+</span>
      <% end %>
    </div>

    <span class="min-w-[3.5rem] text-right text-sm font-bold text-stone-900">
      <%= number_to_currency(order_item.line_total) %>
    </span>

    <%= button_to cart_item_path(order_item), method: :delete, form: { data: { turbo_confirm: "Remove #{order_item.drink.name}?" } }, class: "ml-1 flex h-7 w-7 items-center justify-center rounded-md text-red-400 transition hover:bg-red-50 hover:text-red-600" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd"/>
      </svg>
    <% end %>
  </div>
</div>
