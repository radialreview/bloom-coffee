<% content_for :title, "Order #{@order.order_number} Confirmed" %>

<section class="w-full max-w-md mx-auto mt-[clamp(1rem,6vh,3rem)] px-4">
  <div class="bg-white border border-stone-200 rounded-xl p-5 shadow-sm">
    <div class="text-center">
      <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-emerald-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-emerald-600" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h1 class="mt-3 mb-0 text-xl font-serif font-bold text-stone-900">
        Order <%= @order.order_number %> confirmed
      </h1>
      <p class="mt-1 mb-0 text-stone-500">
        We'll call <strong class="font-semibold text-stone-900"><%= @order.customer_name %></strong> when your order is ready!
      </p>
    </div>

    <div class="mt-6 flex flex-col gap-2">
      <% @order_items.each do |item| %>
        <div class="flex items-start justify-between gap-3 rounded-lg border border-stone-200 bg-stone-50/50 px-3 py-2.5">
          <div class="flex-1">
            <p class="m-0 text-sm font-medium text-stone-900">
              <%= item.drink.name %>
              <span class="text-stone-500">&times; <%= item.quantity %></span>
            </p>
            <% if item.add_ons.any? %>
              <p class="mt-0.5 mb-0 text-xs text-stone-500">
                + <%= item.add_ons.map(&:name).join(", ") %>
              </p>
            <% end %>
          </div>
          <span class="shrink-0 text-sm font-bold text-stone-900">
            <%= number_to_currency(item.line_total) %>
          </span>
        </div>
      <% end %>
    </div>

    <div class="mt-4 flex items-center justify-between border-t border-stone-200 pt-4">
      <span class="text-base font-medium text-stone-700">Total</span>
      <span class="text-lg font-bold text-amber-900"><%= number_to_currency(@order.total) %></span>
    </div>

    <div class="mt-6 text-center">
      <%= link_to "Start a new order", root_path,
            class: "inline-flex rounded-lg bg-amber-800 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-amber-700" %>
    </div>
  </div>
</section>
