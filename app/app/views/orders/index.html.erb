<% content_for :title, "Order" %>

<section class="w-full max-w-md mx-auto mt-[clamp(1rem,6vh,3rem)] px-4">
  <h1 class="m-0 mb-3 text-2xl font-serif font-bold tracking-tight text-center">Your Order</h1>

  <% if @last_order %>
    <div class="bg-white border border-stone-200 rounded-xl p-5 shadow-sm">
      <div class="flex items-center justify-between">
        <p class="m-0 text-xs font-semibold uppercase tracking-wide text-amber-800">Latest Order</p>
        <span class="text-xs font-medium text-stone-500"><%= @last_order.created_at.strftime("%b %d, %Y %l:%M %p") %></span>
      </div>

      <h2 class="mt-2 mb-0 text-lg font-bold text-stone-900">Order <%= @last_order.order_number %></h2>
      <p class="mt-1 mb-0 text-sm text-stone-500">
        Pickup name: <strong class="text-stone-900"><%= @last_order.customer_name %></strong>
      </p>

      <div class="mt-4 flex flex-col gap-2">
        <% @order_items.each do |item| %>
          <div class="flex items-start justify-between gap-3 rounded-lg border border-stone-200 bg-stone-50/50 px-3 py-2.5">
            <div class="flex-1">
              <p class="m-0 text-sm font-medium text-stone-900">
                <%= item.drink.name %>
                <span class="text-stone-500">&times; <%= item.quantity %></span>
              </p>
              <% if item.add_ons.any? %>
                <p class="mt-0.5 mb-0 text-xs text-stone-500">
                  + <%= item.add_ons.map(&:name).join(", ") %>
                </p>
              <% end %>
            </div>
            <span class="shrink-0 text-sm font-bold text-stone-900">
              <%= number_to_currency(item.line_total) %>
            </span>
          </div>
        <% end %>
      </div>

      <div class="mt-4 flex items-center justify-between border-t border-stone-200 pt-4">
        <span class="text-base font-medium text-stone-700">Total</span>
        <span class="text-lg font-bold text-amber-900"><%= number_to_currency(@last_order.total) %></span>
      </div>
    </div>
  <% else %>
    <div class="bg-white border border-stone-200 rounded-xl p-5 shadow-sm">
      <div class="py-4 text-center">
        <p class="m-0 text-stone-500">No orders yet.</p>
        <div class="mt-4">
          <%= link_to "Browse the menu", root_path,
                class: "inline-flex rounded-lg bg-amber-800 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition hover:bg-amber-700" %>
        </div>
      </div>
    </div>
  <% end %>
</section>
