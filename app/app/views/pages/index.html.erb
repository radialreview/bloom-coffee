<div class="mx-auto max-w-lg px-4 py-6">
  <h1 class="text-center text-lg font-semibold text-amber-900">Bloom Coffee</h1>
  <p class="mt-2 text-center text-sm text-stone-600">Menu preview (Story 2). Story 4 will expand this flow.</p>

  <% if @drinks.any? %>
    <ul class="mt-6 space-y-3">
      <% @drinks.each do |drink| %>
        <li class="rounded-xl border border-cream-dark bg-white/90 px-4 py-3 shadow-sm backdrop-blur-sm">
          <div class="font-semibold text-stone-900"><%= drink.name %></div>
          <% if drink.description.present? %>
            <p class="mt-1 text-sm text-stone-600"><%= drink.description %></p>
          <% end %>
          <p class="mt-2 text-sm font-semibold text-amber-900"><%= number_to_currency(drink.price) %></p>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="mt-6 rounded-lg border border-dashed border-stone-300 bg-white/60 px-4 py-8 text-center text-sm text-stone-600">
      No drinks on the menu yet. Sign in as an admin to add drinks.
    </p>
  <% end %>
</div>
