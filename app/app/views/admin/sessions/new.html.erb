<% content_for :title, "Admin sign in" %>

<div class="mx-auto flex w-full max-w-md flex-1 flex-col justify-center py-6 sm:py-10">
  <section
    class="rounded-xl border border-cream-dark bg-white/90 p-6 shadow-sm backdrop-blur-md sm:p-8"
    aria-labelledby="admin-sign-in-heading">
    <header class="mb-6 text-center">
      <h1 id="admin-sign-in-heading" class="text-lg font-semibold tracking-tight text-amber-900">
        Admin sign in
      </h1>
      <p class="mt-1 text-sm text-stone-600">
        Sign in with your administrator account.
      </p>
    </header>

    <%= form_with url: admin_login_path, scope: :session, local: true, class: "space-y-5" do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-stone-700" %>
        <%= f.email_field :email,
              autocomplete: "email",
              required: true,
              class: "mt-1.5 block w-full rounded-lg border border-stone-300 bg-white px-3 py-2.5 text-sm text-stone-900 shadow-sm placeholder:text-stone-400 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/25" %>
      </div>
      <div>
        <%= f.label :password, class: "block text-sm font-medium text-stone-700" %>
        <%= f.password_field :password,
              autocomplete: "current-password",
              required: true,
              class: "mt-1.5 block w-full rounded-lg border border-stone-300 bg-white px-3 py-2.5 text-sm text-stone-900 shadow-sm focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/25" %>
      </div>
      <div class="pt-1">
        <%= f.submit "Sign in",
              class: "w-full cursor-pointer rounded-lg bg-amber-900 px-4 py-2.5 text-sm font-semibold text-amber-50 shadow-sm transition hover:bg-amber-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amber-700 active:bg-amber-950" %>
      </div>
    <% end %>
  </section>
</div>
