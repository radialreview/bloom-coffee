<%= turbo_frame_tag add_on do %>
  <li class="flex items-center justify-between gap-3 px-3 py-2.5 bg-white border border-stone-200 rounded-lg">
    <span class="flex flex-col">
      <span class="font-semibold"><%= add_on.name %></span>
      <small class="text-stone-500">+<%= number_to_currency(add_on.price) %></small>
    </span>

    <span class="flex items-center gap-3">
      <%= link_to "Edit", edit_admin_add_on_path(add_on),
            data: { turbo_frame: dom_id(add_on) },
            class: "text-sm font-semibold text-stone-900 hover:text-amber-800" %>
      <%= button_to "Delete",
            admin_add_on_path(add_on),
            method: :delete,
            form: {
              data: {
                turbo_frame: "_top",
                turbo_confirm: "Delete '#{add_on.name}'? It will disappear from the menu."
              }
            },
            class: "px-3 py-1.5 rounded-lg border border-stone-200 bg-white
                    text-stone-900 text-sm font-semibold cursor-pointer" %>
    </span>
  </li>
<% end %>
