<section class="w-full max-w-md text-left mt-[clamp(1rem,6vh,3rem)]">
  <header class="flex items-baseline justify-between gap-3 mb-2">
    <h1 class="m-0 text-2xl font-bold">Drinks</h1>
    <%= render "admin/drinks/new_drink_trigger" %>
  </header>
  <p class="m-0 mb-5 text-stone-600">Manage the drinks shown on the menu.</p>

  <%= render "admin/drinks/new_drink_frame" %>
  <%= render "admin/drinks/list", drinks: @drinks %>

  <p class="mt-4">
    <%= link_to "Back to admin", admin_root_path,
          class: "text-sm font-semibold text-stone-700 hover:text-amber-800" %>
  </p>
</section>
