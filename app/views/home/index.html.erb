<% content_for :title, "Bloom Coffee" %>

<section class="relative overflow-hidden px-4 pb-20 pt-12 sm:px-6 sm:pt-16 lg:px-8 lg:pb-28">
  <div class="pointer-events-none absolute -right-24 -top-24 h-96 w-96 rounded-full bg-amber-200/40 blur-3xl" aria-hidden="true"></div>
  <div class="pointer-events-none absolute -bottom-32 -left-24 h-80 w-80 rounded-full bg-stone-300/30 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-3xl text-center">
    <p class="font-serif text-sm font-medium uppercase tracking-[0.2em] text-amber-800/90">Est. Bloom</p>
    <h1 class="mt-3 font-serif text-4xl font-semibold tracking-tight text-stone-900 sm:text-5xl sm:leading-tight">
      Coffee, roasted for the neighborhood
    </h1>
    <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-stone-600">
      Order ahead, pick up when it’s ready. Staff use the admin area to keep the menu fresh—customers get the good stuff next.
    </p>
    <div class="mt-10">
      <%= link_to menu_index_path, class: "inline-flex items-center justify-center rounded-xl bg-amber-900 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-amber-900/25 transition hover:bg-amber-800" do %>
        View Menu
      <% end %>
    </div>
  </div>
</section>
