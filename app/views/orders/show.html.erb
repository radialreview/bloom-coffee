<% content_for :title, "Order #{@order.order_number} Confirmed — Bloom Coffee" %>

<section class="mx-auto max-w-2xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-2xl border border-stone-200/80 bg-white p-8 shadow-xl shadow-stone-200/50 sm:p-10">
    <div class="text-center">
      <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-green-100">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-green-600" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
      </div>
      <h1 class="mt-4 font-serif text-2xl font-semibold text-stone-900 sm:text-3xl">
        Order <%= @order.order_number %> confirmed
      </h1>
      <p class="mt-2 text-lg text-stone-600">
        We'll call <strong class="font-semibold text-stone-900"><%= @order.customer_name %></strong> when your order is ready!
      </p>
    </div>

    <div class="mt-8 space-y-3">
      <% @order_items.each do |item| %>
        <div class="flex items-start justify-between gap-4 rounded-xl border border-stone-200 bg-stone-50/50 px-4 py-3">
          <div class="flex-1">
            <p class="font-medium text-stone-900">
              <%= item.drink.name %>
              <span class="text-stone-500">&times; <%= item.quantity %></span>
            </p>
            <% if item.add_ons.any? %>
              <p class="mt-0.5 text-sm text-stone-500">
                + <%= item.add_ons.map(&:name).join(", ") %>
              </p>
            <% end %>
          </div>
          <span class="shrink-0 text-sm font-bold text-stone-900">
            <%= number_to_currency(item.line_total) %>
          </span>
        </div>
      <% end %>
    </div>

    <div class="mt-5 flex items-center justify-between border-t border-stone-200 pt-5">
      <span class="text-base font-medium text-stone-700">Total</span>
      <span class="text-xl font-bold text-amber-900"><%= number_to_currency(@order.total) %></span>
    </div>

    <div class="mt-8 text-center">
      <%= link_to "Start a new order", menu_index_path, class: "inline-flex rounded-xl bg-amber-900 px-6 py-3 text-sm font-semibold text-white shadow-md shadow-amber-900/20 transition hover:bg-amber-800" %>
    </div>
  </div>
</section>
