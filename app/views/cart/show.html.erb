<% content_for :title, "Your Order — Bloom Coffee" %>

<section class="mx-auto max-w-2xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-2xl border border-stone-200/80 bg-white p-8 shadow-xl shadow-stone-200/50 sm:p-10">
    <% if @order_items.any? %>
      <div class="mb-6">
        <%= link_to menu_index_path, class: "text-sm font-medium text-amber-900 underline decoration-amber-900/30 underline-offset-2 transition hover:text-amber-800" do %>
          ← Back to menu
        <% end %>
      </div>
    <% end %>

    <p class="text-sm font-medium uppercase tracking-wide text-amber-800">Your Order</p>
    <h1 class="mt-2 font-serif text-2xl font-semibold text-stone-900 sm:text-3xl">Order summary</h1>

    <% if @order_items.any? %>
      <div class="mt-6 space-y-3">
        <% @order_items.each do |item| %>
          <%= render "cart/items/order_item", order_item: item %>
        <% end %>
      </div>

      <div class="mt-6 flex items-center justify-between border-t border-stone-200 pt-5">
        <span class="text-base font-medium text-stone-700">Order total</span>
        <span class="text-xl font-bold text-amber-900"><%= number_to_currency(@order.total) %></span>
      </div>

      <div class="mt-6 text-center">
        <%= link_to menu_index_path, class: "inline-flex items-center justify-center rounded-xl border border-stone-300 bg-white px-5 py-3 text-sm font-semibold text-stone-700 transition hover:border-stone-400 hover:bg-stone-50" do %>
          + Add more drinks
        <% end %>
      </div>

      <div class="mt-6 rounded-xl border border-stone-200 bg-stone-50/50 p-6">
        <h2 class="font-serif text-lg font-semibold text-stone-900">Ready to order?</h2>
        <%= form_with url: orders_path, method: :post, class: "mt-4" do |f| %>
          <div>
            <label for="order_customer_name" class="block text-sm font-medium text-stone-700">Name for pickup</label>
            <input type="text" name="order[customer_name]" id="order_customer_name" value="<%= @order.customer_name %>" placeholder="e.g. Jordan" class="mt-1.5 block w-full rounded-xl border border-stone-300 bg-white px-4 py-3 text-stone-900 shadow-sm transition placeholder:text-stone-400 focus:border-amber-500 focus:outline-none focus:ring-2 focus:ring-amber-500/30">
          </div>
          <div class="mt-4">
            <%= f.submit "Place order", class: "cursor-pointer rounded-xl bg-amber-900 px-6 py-3 text-sm font-semibold text-white shadow-md shadow-amber-900/20 transition hover:bg-amber-800 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" %>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="mt-8 text-center">
        <p class="text-stone-500">Your order is empty.</p>
        <div class="mt-6">
          <%= link_to "Browse the menu", menu_index_path, class: "inline-flex rounded-xl bg-amber-900 px-6 py-3 text-sm font-semibold text-white shadow-md shadow-amber-900/20 transition hover:bg-amber-800" %>
        </div>
      </div>
    <% end %>
  </div>
</section>
