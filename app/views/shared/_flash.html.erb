<% if notice.present? %>
  <div class="mx-auto max-w-3xl px-4 pt-4 sm:px-6 lg:px-8" role="status" data-turbo-temporary>
    <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900 shadow-sm">
      <%= notice %>
    </div>
  </div>
<% end %>
<% if alert.present? %>
  <div class="mx-auto max-w-3xl px-4 pt-4 sm:px-6 lg:px-8" role="alert" data-turbo-temporary>
    <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-900 shadow-sm">
      <%= alert %>
    </div>
  </div>
<% end %>
