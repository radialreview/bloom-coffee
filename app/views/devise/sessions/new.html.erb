<% content_for :title, "Staff sign in — Bloom Coffee" %>

<div class="mx-auto max-w-md px-4 py-12 sm:px-6 lg:px-8">
  <div class="rounded-2xl border border-stone-200/80 bg-white p-8 shadow-xl shadow-stone-200/50 sm:p-10">
    <div class="text-center">
      <h1 class="font-serif text-2xl font-semibold text-stone-900">Staff sign in</h1>
      <p class="mt-2 text-sm text-stone-600">Bloom Coffee admin &amp; barista access</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
      <div>
        <%= f.label :email, class: "block text-sm font-medium text-stone-700" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "mt-1.5 block w-full rounded-xl border border-stone-300 bg-stone-50/50 px-4 py-3 text-stone-900 shadow-sm transition placeholder:text-stone-400 focus:border-amber-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-amber-500/30" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-stone-700" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "mt-1.5 block w-full rounded-xl border border-stone-300 bg-stone-50/50 px-4 py-3 text-stone-900 shadow-sm transition focus:border-amber-500 focus:bg-white focus:outline-none focus:ring-2 focus:ring-amber-500/30" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center gap-2">
          <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-stone-300 text-amber-900 focus:ring-amber-500" %>
          <%= f.label :remember_me, class: "text-sm text-stone-600" %>
        </div>
      <% end %>

      <div class="pt-2">
        <%= f.submit "Sign in", class: "w-full cursor-pointer rounded-xl bg-amber-900 px-4 py-3.5 text-sm font-semibold text-white shadow-md shadow-amber-900/20 transition hover:bg-amber-800 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" %>
      </div>
    <% end %>

  </div>
</div>
