<% content_for :title, "#{@add_on.name} — Bloom Coffee" %>

<div class="mx-auto max-w-xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-2xl border border-stone-200/80 bg-white p-8 shadow-xl shadow-stone-200/50 sm:p-10">
    <p class="text-sm font-medium uppercase tracking-wide text-amber-800">Admin · Add-On</p>
    <h1 class="mt-2 font-serif text-3xl font-semibold text-stone-900"><%= @add_on.name %></h1>
    <p class="mt-4 text-lg font-semibold text-stone-800">+<%= number_to_currency(@add_on.price) %></p>

    <div class="mt-8 flex flex-wrap gap-3">
      <%= link_to "Edit", edit_admin_add_on_path(@add_on), class: "inline-flex rounded-xl bg-amber-900 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-amber-900/20 transition hover:bg-amber-800" %>
      <%= link_to "← Back to add-ons", admin_add_ons_path, class: "inline-flex rounded-xl border border-stone-300 bg-white px-5 py-2.5 text-sm font-semibold text-stone-700 transition hover:border-stone-400 hover:bg-stone-50" %>
    </div>
  </div>
</div>
