<% content_for :title, "Manage Drinks — Bloom Coffee" %>

<div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-2xl border border-stone-200/80 bg-white p-8 shadow-xl shadow-stone-200/50 sm:p-10">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <p class="text-sm font-medium uppercase tracking-wide text-amber-800">Admin</p>
        <h1 class="mt-2 font-serif text-3xl font-semibold text-stone-900">Drinks</h1>
      </div>
      <%= link_to "New drink", new_admin_drink_path, class: "inline-flex rounded-xl bg-amber-900 px-5 py-2.5 text-sm font-semibold text-white shadow-md shadow-amber-900/20 transition hover:bg-amber-800" %>
    </div>

    <% if @drinks.any? %>
      <div class="mt-6 divide-y divide-stone-100">
        <% @drinks.each do |drink| %>
          <div class="flex items-start justify-between gap-4 py-4">
            <div class="min-w-0 flex-1">
              <h3 class="font-medium text-stone-900"><%= drink.name %></h3>
              <% if drink.description.present? %>
                <p class="mt-0.5 text-sm text-stone-500 line-clamp-1"><%= drink.description %></p>
              <% end %>
            </div>
            <div class="flex shrink-0 items-center gap-3">
              <span class="text-sm font-semibold text-stone-700"><%= number_to_currency(drink.base_price) %></span>
              <%= link_to "Edit", edit_admin_drink_path(drink), class: "text-sm font-medium text-amber-900 underline decoration-amber-900/30 underline-offset-2 transition hover:text-amber-800" %>
              <%= button_to "Delete", admin_drink_path(drink), method: :delete, form: { data: { turbo_confirm: "Delete #{drink.name}?" } }, class: "text-sm font-medium text-red-600 underline decoration-red-600/30 underline-offset-2 transition hover:text-red-800" %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mt-6 text-stone-500">No drinks yet. Add your first one above.</p>
    <% end %>

    <div class="mt-8">
      <%= link_to "← Back to dashboard", admin_root_path, class: "text-sm font-medium text-amber-900 underline decoration-amber-900/30 underline-offset-2 transition hover:text-amber-800" %>
    </div>
  </div>
</div>
