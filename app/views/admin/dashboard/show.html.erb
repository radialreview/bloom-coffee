<% content_for :title, "Admin — Bloom Coffee" %>

<div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-2xl border border-stone-200/80 bg-white p-8 shadow-xl shadow-stone-200/50 sm:p-10">
    <p class="text-sm font-medium uppercase tracking-wide text-amber-800">Admin</p>
    <h1 class="mt-2 font-serif text-3xl font-semibold text-stone-900">Dashboard</h1>
    <p class="mt-3 text-stone-600">
      Welcome to the Bloom Coffee admin area. Manage your menu below.
    </p>

    <div class="mt-8 grid gap-4 sm:grid-cols-2">
      <%= link_to admin_drinks_path, class: "group rounded-xl border border-stone-200 bg-stone-50/50 p-6 transition hover:border-amber-300 hover:bg-amber-50/50" do %>
        <h2 class="font-serif text-lg font-semibold text-stone-900 group-hover:text-amber-900">Manage Drinks</h2>
        <p class="mt-1 text-sm text-stone-500 group-hover:text-amber-800/70">Create, edit, and remove drinks from the menu.</p>
      <% end %>

      <%= link_to admin_add_ons_path, class: "group rounded-xl border border-stone-200 bg-stone-50/50 p-6 transition hover:border-amber-300 hover:bg-amber-50/50" do %>
        <h2 class="font-serif text-lg font-semibold text-stone-900 group-hover:text-amber-900">Manage Add-Ons</h2>
        <p class="mt-1 text-sm text-stone-500 group-hover:text-amber-800/70">Create, edit, and remove add-ons like oat milk or extra shot.</p>
      <% end %>
    </div>

    <div class="mt-8">
      <%= link_to "View site", root_path, class: "inline-flex rounded-xl border border-stone-300 bg-white px-5 py-2.5 text-sm font-semibold text-stone-700 transition hover:border-stone-400 hover:bg-stone-50" %>
    </div>
  </div>
</div>
