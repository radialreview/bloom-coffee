<% content_for :title, "#{@drink.name} — Bloom Coffee" %>

<section class="mx-auto max-w-xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="rounded-2xl border border-stone-200/80 bg-white p-8 shadow-xl shadow-stone-200/50 sm:p-10">
    <p class="text-sm font-medium uppercase tracking-wide text-amber-800">Customize</p>
    <h1 class="mt-2 font-serif text-2xl font-semibold text-stone-900 sm:text-3xl"><%= @drink.name %></h1>
    <% if @drink.description.present? %>
      <p class="mt-2 text-stone-500"><%= @drink.description %></p>
    <% end %>
    <p class="mt-3 text-lg font-semibold text-stone-800">Base price: <%= number_to_currency(@drink.base_price) %></p>

    <%= form_with url: cart_items_path, method: :post, class: "mt-6", data: { controller: "line-total", line_total_base_price_value: @drink.base_price } do |f| %>
      <input type="hidden" name="order_item[drink_id]" value="<%= @drink.id %>">

      <% if @add_ons.any? %>
        <fieldset class="mt-2">
          <legend class="text-sm font-medium text-stone-700">Add extras</legend>
          <div class="mt-3 max-h-64 space-y-3 overflow-y-auto">
            <% @add_ons.each do |add_on| %>
              <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-stone-200 px-4 py-3 transition hover:border-amber-300 hover:bg-amber-50/30 has-[:checked]:border-amber-400 has-[:checked]:bg-amber-50/50">
                <input type="checkbox"
                       name="order_item[order_item_add_ons_attributes][][add_on_id]"
                       value="<%= add_on.id %>"
                       data-line-total-target="checkbox"
                       data-price="<%= add_on.price %>"
                       data-action="change->line-total#calculate"
                       class="h-4 w-4 rounded border-stone-300 text-amber-900 focus:ring-amber-500">
                <span class="flex flex-1 items-center justify-between">
                  <span class="text-sm font-medium text-stone-800"><%= add_on.name %></span>
                  <span class="text-sm font-semibold text-stone-600">+<%= number_to_currency(add_on.price) %></span>
                </span>
              </label>
            <% end %>
          </div>
        </fieldset>
      <% end %>

      <div class="mt-6 flex items-center justify-between rounded-xl bg-stone-50 px-4 py-3">
        <span class="text-sm font-medium text-stone-600">Item total</span>
        <span class="text-lg font-bold text-amber-900" data-line-total-target="display">
          <%= number_to_currency(@drink.base_price) %>
        </span>
      </div>

      <div class="mt-6 flex items-center gap-3">
        <input type="hidden" name="order_item[quantity]" value="1">
        <%= f.submit "Add to order", class: "flex-1 cursor-pointer rounded-xl bg-amber-900 px-6 py-3 text-sm font-semibold text-white shadow-md shadow-amber-900/20 transition hover:bg-amber-800 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:ring-offset-2" %>
        <%= link_to "← Back to menu", menu_index_path, class: "rounded-xl border border-stone-300 bg-white px-5 py-2.5 text-sm font-semibold text-stone-700 transition hover:border-stone-400 hover:bg-stone-50" %>
      </div>
    <% end %>
  </div>
</section>
