<% content_for :title, "Menu — Bloom Coffee" %>

<section class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-8">
  <div class="text-center">
    <p class="text-sm font-medium uppercase tracking-[0.2em] text-amber-800/90">Our Menu</p>
    <h1 class="mt-2 font-serif text-3xl font-semibold tracking-tight text-stone-900 sm:text-4xl">
      Pick your drink
    </h1>
    <p class="mx-auto mt-3 max-w-lg text-stone-500">
      Choose a drink, add your favorite extras, and we'll have it ready for you.
    </p>
  </div>

  <% if @drinks.any? %>
    <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      <% @drinks.each do |drink| %>
        <%= link_to menu_path(drink), class: "group rounded-2xl border border-stone-200/80 bg-white p-6 shadow-sm transition hover:border-amber-300 hover:shadow-md" do %>
          <h2 class="font-serif text-lg font-semibold text-stone-900 group-hover:text-amber-900">
            <%= drink.name %>
          </h2>
          <% if drink.description.present? %>
            <p class="mt-1.5 text-sm leading-relaxed text-stone-500 line-clamp-2">
              <%= drink.description %>
            </p>
          <% end %>
          <p class="mt-3 text-base font-semibold text-amber-900">
            <%= number_to_currency(drink.base_price) %>
          </p>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <p class="mt-10 text-center text-stone-500">No drinks on the menu yet. Check back soon!</p>
  <% end %>
</section>
